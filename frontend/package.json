{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5173",
    "build": "tsc -b && vite build",
    "build:analyze": "ANALYZE=true tsc -b && ANALYZE=true vite build",
    "lint": "eslint .",
    "check:tokens": "node scripts/check-semantic-tokens.mjs",
    "check:tokens:strict": "node scripts/check-semantic-tokens.mjs --strict",
    "check:tokens:layout": "node scripts/check-semantic-tokens.mjs --scope=layout",
    "check:tokens:strict:layout": "node scripts/check-semantic-tokens.mjs --scope=layout --strict",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@sentry/react": "^8.50.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-virtual": "^3.13.18",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@zip.js/zip.js": "^2.7.29",
    "autoprefixer": "^10.4.23",
    "axios": "^1.13.2",
    "bootstrap-icons": "^1.11.3",
    "clsx": "^2.1.1",
    "giframe": "^0.2.0",
    "hls.js": "^1.6.15",
    "js-sha256": "^0.10.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.563.0",
    "pdfjs-dist": "^4.10.38",
    "postcss": "^8.5.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.12.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "three": "^0.179.1",
    "web-vitals": "^5.1.0",
    "zod": "^4.3.5",
    "zustand": "^5.0.10"

{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "UploadDownloadUtil",
  "version": "0.1.0",
  "identifier": "com.upload-download-util.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Upload Download Util",
        "width": 430,
        "height": 932,
        "resizable": false,
        "fullscreen": false,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "transparent": false,
        "backgroundColor": "#020617"
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

# Database
DATABASE_URL=postgresql://file_storage:file_storage_password@localhost:5432/file_storage
# 连接池（可选，高并发或批量下载时可调大）
# DB_POOL_MAX_CONNECTIONS=40
# DB_POOL_ACQUIRE_TIMEOUT_SECS=15

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=24h

# Storage
STORAGE_BACKEND=local
STORAGE_PATH=./uploads

# AWS S3 (optional, if using S3 storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET=

# File Upload Limits
# 2GB = 2147483648 bytes (支持大视频文件)
MAX_FILE_SIZE=2147483648
# 允许的 MIME 类型（使用 */* 表示允许所有，或指定具体类型如 image/*,video/*,audio/*）
ALLOWED_MIME_TYPES=*/*

# Server
PORT=3000
CORS_ORIGIN=http://localhost:5173,http://192.168.0.3:5173,http://files.local:5173

# HLS（超大视频预览，> 阈值时转码为 .m3u8 + ts，需安装 ffmpeg；仅 local 存储）
# 默认 104857600 = 100MB
# HLS_THRESHOLD_BYTES=104857600

# SMTP（修改邮箱验证码发送；不配置则验证码仅写入日志）
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@yourdomain.com

# OAuth（GitHub 登录，可选）
# GitHub OAuth 应用配置请参考 https://github.com/settings/developers
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
# 回调地址需与 GitHub 应用中的 Authorization callback URL 保持一致
# 例如：http://files.local:3000/api/auth/oauth/github/callback
# GITHUB_OAUTH_REDIRECT_URI=http://files.local:3000/api/auth/oauth/github/callback

# 前端基础地址（用于 OAuth 登录成功后重定向回前端）
# 例如：http://files.local:5173 或 https://files.yourdomain.com
# FRONTEND_BASE_URL=http://files.local:5173

# Database
DATABASE_URL=postgresql://file_storage:file_storage_password@localhost:5432/file_storage

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=24h

# Storage
STORAGE_BACKEND=local
STORAGE_PATH=./uploads

# AWS S3 (optional, if using S3 storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_BUCKET=

# File Upload Limits
MAX_FILE_SIZE=104857600
ALLOWED_MIME_TYPES=image/*,application/pdf,text/*,application/zip,application/x-zip-compressed

# Server
PORT=3000
CORS_ORIGIN=*
